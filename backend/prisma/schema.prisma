generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User model for auth (Integrating with Firebase)
model User {
  id          String     @id @default(uuid())
  email       String     @unique
  firebaseUid String     @unique // Links local user profile to Firebase identity
  name        String
  role        Role       @default(VIEWER)
  status      UserStatus @default(ACTIVE)

  transactions Transaction[] @relation("CreatedTransactions")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  ADMIN
  MANAGER
  STAFF
  VIEWER
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

// Physical or logical locations
model Location {
  id     String         @id @default(uuid())
  code   String         @unique // e.g., "WH-A1"
  name   String
  type   LocationType
  status LocationStatus @default(ACTIVE)

  stocks Stock[]
  moves  StockMove[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum LocationType {
  WAREHOUSE
  STORE
  INTERNAL // e.g., Transit or holding areas
}

enum LocationStatus {
  ACTIVE
  INACTIVE
}

// Product classifications
model Category {
  id          String    @id @default(uuid())
  name        String    @unique
  description String?
  products    Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Items held in inventory
model Product {
  id          String  @id @default(uuid())
  sku         String  @unique
  name        String
  description String?

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  minStockLevel Int           @default(0)
  status        ProductStatus @default(ACTIVE)

  stocks Stock[]
  lines  TransactionLine[]
  moves  StockMove[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ProductStatus {
  ACTIVE
  INACTIVE
  DISCONTINUED
}

// Current stock levels per location
model Stock {
  id         String   @id @default(uuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id])
  locationId String
  location   Location @relation(fields: [locationId], references: [id])

  quantity           Int      @default(0) // Can be negative for specific operational needs (e.g. oversold), though logic should prevent
  lastCalculatedDate DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, locationId])
}

// The core operational document (Receipt, Delivery, Transfer, Adjustment)
model Transaction {
  id          String            @id @default(uuid())
  type        TransactionType
  status      TransactionStatus @default(DRAFT)
  referenceNo String            @unique // Auto-generated document number (e.g. REC-2026-0001)

  // Storing source/dest context directly on the transaction to decouple from specific models,
  // making it flexible for transfers vs receipts
  sourceConfig      Json? // e.g., { type: "VENDOR", id: "ven_1" } or { type: "LOCATION", id: "loc_1" }
  destinationConfig Json? // e.g., { type: "LOCATION", id: "loc_2" }

  createdById String
  createdBy   User   @relation("CreatedTransactions", fields: [createdById], references: [id])

  totalVolume Int? // Cached total quantity for quick querying
  notes       String?

  lines TransactionLine[]
  moves StockMove[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum TransactionType {
  RECEIPT
  DELIVERY
  TRANSFER
  ADJUSTMENT
}

enum TransactionStatus {
  DRAFT
  PENDING
  COMPLETED
  CANCELLED
}

// Items within a transaction
model TransactionLine {
  id            String      @id @default(uuid())
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  productId     String
  product       Product     @relation(fields: [productId], references: [id])

  quantity Int
  notes    String?
}

// The immutable ledger of all stock changes
model StockMove {
  id            String      @id @default(uuid())
  productId     String
  product       Product     @relation(fields: [productId], references: [id])
  locationId    String
  location      Location    @relation(fields: [locationId], references: [id])
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id])

  quantity Int // (+) for inward movement, (-) for outward
  date     DateTime @default(now())

  createdAt DateTime @default(now())
}
