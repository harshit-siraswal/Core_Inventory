# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/core_inventory?schema=public"

# JWT
JWT_SECRET="change-this-to-a-random-secret-in-production"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
JWT_REFRESH_SECRET="change-this-to-a-different-random-secret-in-production" # must differ from JWT_SECRET, min 32 chars, high entropy

# App
PORT=3000
